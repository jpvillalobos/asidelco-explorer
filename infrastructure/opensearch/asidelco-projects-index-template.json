{
  "index_patterns": [
    "asidelco-explorer*"
  ],
  "priority": 500,
  "version": 1,
  "_meta": {
    "description": "ASIDELCO project search index template for OpenSearch dashboards, geospatial search, and vector search.",
    "source_file": "data/output/search_ready.json",
    "embedding_model": "text-embedding-3-small",
    "embedding_dimension": 1536
  },
  "template": {
    "settings": {
      "index": {
        "number_of_shards": 1,
        "number_of_replicas": 0,
        "refresh_interval": "30s",
        "knn": true,
        "knn.algo_param.ef_search": 100,
        "mapping.total_fields.limit": 1000
      },
      "analysis": {
        "normalizer": {
          "lowercase_keyword": {
            "type": "custom",
            "filter": [
              "lowercase",
              "asciifolding"
            ]
          }
        },
        "analyzer": {
          "asidelco_text": {
            "type": "custom",
            "tokenizer": "standard",
            "filter": [
              "lowercase",
              "asciifolding"
            ]
          },
          "asidelco_spanish": {
            "type": "spanish"
          }
        }
      }
    },
    "mappings": {
      "dynamic": true,
      "dynamic_templates": [
        {
          "strings_as_searchable_text": {
            "match_mapping_type": "string",
            "mapping": {
              "type": "text",
              "analyzer": "asidelco_text",
              "fields": {
                "keyword": {
                  "type": "keyword",
                  "normalizer": "lowercase_keyword",
                  "ignore_above": 512
                }
              }
            }
          }
        }
      ],
      "properties": {
        "record_id": {
          "type": "keyword",
          "normalizer": "lowercase_keyword"
        },
        "csv_id": {
          "type": "keyword",
          "normalizer": "lowercase_keyword"
        },
        "csv_proyecto": {
          "type": "long"
        },
        "csv_proyecto_num": {
          "type": "long"
        },
        "csv_area": {
          "type": "double"
        },
        "csv_area_num": {
          "type": "double"
        },
        "csv_provincia": {
          "type": "text",
          "analyzer": "asidelco_text",
          "fields": {
            "keyword": {
              "type": "keyword",
              "normalizer": "lowercase_keyword",
              "ignore_above": 128
            }
          }
        },
        "csv_canton": {
          "type": "text",
          "analyzer": "asidelco_text",
          "fields": {
            "keyword": {
              "type": "keyword",
              "normalizer": "lowercase_keyword",
              "ignore_above": 128
            }
          }
        },
        "csv_distrito": {
          "type": "text",
          "analyzer": "asidelco_text",
          "fields": {
            "keyword": {
              "type": "keyword",
              "normalizer": "lowercase_keyword",
              "ignore_above": 128
            }
          }
