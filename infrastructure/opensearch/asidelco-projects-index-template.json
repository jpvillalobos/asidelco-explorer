        "csv_exonerado": {
          "type": "keyword",
          "normalizer": "lowercase_keyword",
          "ignore_above": 32
        },
        "csv_fechaproyecto": {
          "type": "date",
          "format": "strict_date_optional_time||yyyy-MM-dd||epoch_millis",
          "ignore_malformed": true
        },
        "csv_obra": {
          "type": "keyword",
          "normalizer": "lowercase_keyword",
          "ignore_above": 128
        },
        "csv_subobra": {
          "type": "keyword",
          "normalizer": "lowercase_keyword",
